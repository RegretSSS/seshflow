{
  "name": "@seshflow/shared",
  "version": "1.4.2",
  "description": "Seshflow shared contracts and workspace snapshot utilities",
  "type": "module",
  "exports": {
    "./types/task.d.ts": "./types/task.d.ts",
    "./constants/statuses.js": "./constants/statuses.js",
    "./constants/transitions.js": "./constants/transitions.js",
    "./constants/hooks.js": "./constants/hooks.js",
    "./constants/announcements.js": "./constants/announcements.js",
    "./constants/contracts.js": "./constants/contracts.js",
    "./constants/handoffs.js": "./constants/handoffs.js",
    "./constants/modes.js": "./constants/modes.js",
    "./constants/integration.js": "./constants/integration.js",
    "./constants/context-priority.js": "./constants/context-priority.js",
    "./workspace-snapshot.js": "./workspace-snapshot.js"
  },
  "files": [
    "types",
    "constants",
    "workspace-snapshot.js",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node -e \"console.log('No tests for @seshflow/shared yet.')\"",
    "test:coverage": "node -e \"console.log('No coverage for @seshflow/shared yet.')\"",
    "lint": "tsc --noEmit",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});\""
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "keywords": [
    "runtime-control-plane",
    "shared-contracts",
    "workspace-snapshot",
    "ai-assistant"
  ],
  "author": "Seshflow Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/RegretSSS/seshflow.git"
  },
  "homepage": "https://github.com/RegretSSS/seshflow#readme",
  "bugs": {
    "url": "https://github.com/RegretSSS/seshflow/issues"
  },
  "license": "MIT"
}
