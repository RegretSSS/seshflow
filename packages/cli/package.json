{
  "name": "@seshflow/cli",
  "version": "1.4.3",
  "description": "Seshflow CLI - Runtime control plane for AI-assisted development",
  "type": "module",
  "author": "Seshflow Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RegretSSS/seshflow.git"
  },
  "homepage": "https://github.com/RegretSSS/seshflow#readme",
  "bugs": {
    "url": "https://github.com/RegretSSS/seshflow/issues"
  },
  "keywords": [
    "ai-assistant",
    "runtime-control-plane",
    "session-recovery",
    "task-runtime",
    "cli",
    "developer-tools"
  ],
  "bin": {
    "seshflow": "./bin/seshflow.js"
  },
  "files": [
    "bin",
    "src",
    "!src/**/*.test.js"
  ],
  "scripts": {
    "dev": "node bin/seshflow.js",
    "build": "node -e \"console.log('CLI is plain JavaScript; no compilation step required.')\"",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --passWithNoTests --testTimeout=15000",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --coverage --passWithNoTests --testTimeout=15000",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});\"",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@seshflow/shared": "1.4.2",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "inquirer": "^9.2.14",
    "conf": "^12.0.0",
    "uuid": "^9.0.1",
    "simple-git": "^3.22.0",
    "yaml": "^2.3.4",
    "cli-table3": "^0.6.3",
    "ora": "^8.0.1",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8",
    "@types/inquirer": "^9.0.7",
    "@types/fs-extra": "^11.0.4",
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "win32",
    "darwin",
    "linux"
  ]
}
