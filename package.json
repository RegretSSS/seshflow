{
  "name": "seshflow-monorepo",
  "version": "1.2.0",
  "private": true,
  "description": "Seshflow monorepo - AI development runtime control plane",
  "scripts": {
    "dev:cli": "pnpm --filter @seshflow/cli dev",
    "dev:web": "pnpm --filter @seshflow/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r --if-present test",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "clean": "pnpm -r clean",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "prettier": "^3.2.4",
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "keywords": [
    "runtime-control-plane",
    "ai-assistant",
    "session-recovery",
    "task-runtime",
    "workflow-control",
    "cli"
  ],
  "author": "",
  "license": "MIT"
}
